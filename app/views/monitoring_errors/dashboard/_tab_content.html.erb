<% content_for :header_tags do %>
  <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" %>
  <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js" %>
  <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/chartkick@4.2.0/dist/chartkick.min.js" %>
<% end %>

<div id="mm-tab-dashboard" class="mm-tabpanel">
  <div class="mm-hint"><%= l(:label_dashboard_hint) %></div>

  <% health = @dashboard.health %>
  <div class="mm-health">
    <div class="mm-health-section">
      <h4 class="mm-chart-title"><%= l(:label_health_status) %></h4>
      <div class="mm-health-grid">
        <% health.settings_status.each do |key, enabled| %>
          <div class="mm-health-item">
            <span><%= l("label_health_#{key}") %></span>
            <span class="mm-badge <%= enabled ? 'mm-badge__active' : 'mm-badge__not_active' %>"></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mm-health-section">
      <h4 class="mm-chart-title"><%= l(:label_health_counts) %></h4>
      <div class="mm-health-grid">
        <% health.counts.each do |key, count| %>
          <div class="mm-health-item">
            <span><%= l("label_health_count_#{key}") %></span>
            <strong><%= count %></strong>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mm-health-section">
      <h4 class="mm-chart-title"><%= l(:label_health_latest) %></h4>
      <table class="mm-table mm-health-table">
        <tbody>
          <% health.latest.each do |key, record| %>
            <tr>
              <td><%= l("label_health_latest_#{key}") %></td>
              <td>
                <% if record %>
                  <%= format_time(record.created_at) if record.respond_to?(:created_at) %>
                <% else %>
                  <span class="mm-muted"><%= l(:label_health_no_data) %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mm-health-section">
      <h4 class="mm-chart-title"><%= l(:label_health_notifications) %></h4>
      <table class="mm-table mm-health-table">
        <tbody>
          <tr>
            <td><%= l(:label_health_active_channels) %></td>
            <td><%= health.notifications[:active_channels].presence&.join(', ') || l(:label_health_no_data) %></td>
          </tr>
          <tr>
            <td><%= l(:label_health_email_configured) %></td>
            <td>
              <span class="mm-badge <%= health.notifications[:email_configured] ? 'mm-badge__active' : 'mm-badge__not_active' %>"></span>
              <%= health.notifications[:email_recipients_count] %>
            </td>
          </tr>
          <tr>
            <td><%= l(:label_health_telegram_configured) %></td>
            <td>
              <span class="mm-badge <%= health.notifications[:telegram_configured] ? 'mm-badge__active' : 'mm-badge__not_active' %>"></span>
              <%= health.notifications[:telegram_chat_ids_count] %>
            </td>
          </tr>
          <tr>
            <td><%= l(:label_health_last_delivery_status) %></td>
            <td><%= health.notifications[:last_status].presence || l(:label_health_no_data) %></td>
          </tr>
          <tr>
            <td><%= l(:label_health_last_delivery_error) %></td>
            <td><%= health.notifications[:last_error].presence || '-' %></td>
          </tr>
          <tr>
            <td><%= l(:label_health_last_sent_at) %></td>
            <td><%= health.notifications[:last_sent_at] ? format_time(health.notifications[:last_sent_at]) : l(:label_health_no_data) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mm-kpis">
    <div class="mm-kpi">
      <div class="mm-kpi-value"><%= @dashboard.kpi_5xx %></div>
      <div class="mm-kpi-label"><%= l(:label_kpi_5xx) %></div>
    </div>
    <div class="mm-kpi">
      <div class="mm-kpi-value"><%= @dashboard.kpi_4xx %></div>
      <div class="mm-kpi-label"><%= l(:label_kpi_4xx) %></div>
    </div>
    <div class="mm-kpi">
      <div class="mm-kpi-value"><%= @dashboard.kpi_slow %></div>
      <div class="mm-kpi-label"><%= l(:label_kpi_slow) %></div>
    </div>
    <div class="mm-kpi">
      <div class="mm-kpi-value"><%= @dashboard.kpi_avg_ms %> <%= l(:label_time_ms) %></div>
      <div class="mm-kpi-label"><%= l(:label_kpi_average) %></div>
    </div>
  </div>

  <div class="mm-charts">
    <div class="mm-chart">
      <h4 class="mm-chart-title"><%= l(:label_chart_errors_by_day) %></h4>
      <%= line_chart(@dashboard.errors_by_day, library: { legend: { position: "none" } }, id: "chart-errors-by-day", refresh: 0) %>
    </div>
    <div class="mm-chart">
      <h4 class="mm-chart-title"><%= l(:label_chart_average_duration) %></h4>
      <%= line_chart(@dashboard.avg_duration, library: { legend: { position: "none" } }, id: "chart-avg-duration", refresh: 0) %>
    </div>
  </div>

  <div class="mm-tops">
    <div class="mm-top">
      <h4 class="mm-chart-title"><%= l(:label_top_urls) %></h4>
      <table class="mm-table">
        <thead>
          <tr>
            <th><%= l(:label_url) %></th>
            <th><%= l(:label_errors) %></th>
          </tr>
        </thead>
        <tbody>
          <% @dashboard.top_urls.each do |top_url| %>
            <% url, error = top_url %>
            <tr>
              <td><%= url %></td>
              <td><%= error %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mm-top">
      <h4 class="mm-chart-title"><%= l(:label_top_users) %></h4>
      <table class="mm-table">
        <thead>
          <tr>
            <th><%= l(:label_user) %></th>
            <th><%= l(:label_errors) %></th>
          </tr>
        </thead>
        <tbody>
          <% @dashboard.top_users.each do |top_user| %>
            <% user, error = top_user %>
            <tr>
              <td><%= user %></td>
              <td><%= error %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
